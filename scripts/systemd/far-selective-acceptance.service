[Unit]
Description=FAR P14 preregistered selective-acceptance study
Wants=far-ollama-selective-acceptance.service
After=far-ollama-selective-acceptance.service

[Service]
Type=simple
WorkingDirectory=/mnt/d/FAR-workspace/FAR-longterm
Environment=PYTHONUNBUFFERED=1
ExecStartPre=/bin/bash -lc 'while :; do stable=1; for _ in 1 2 3; do curl -fsS --max-time 5 http://127.0.0.1:11434/api/tags >/dev/null || { stable=0; break; }; sleep 2; done; (( stable )) && exit 0; sleep 2; done'
ExecStart=/bin/bash -lc 'source ~/miniconda3/etc/profile.d/conda.sh; conda activate train; source scripts/windows_gpu_env.sh; echo P14_START $(date -Is) commit=$(git rev-parse HEAD); exec python -m far.experiments.selective_acceptance run --output-root /mnt/d/FAR-outputs/selective_acceptance_v2'
ExecStopPost=/bin/bash -lc '[[ "${SERVICE_RESULT}" == "success" ]] && systemctl --user stop --no-block far-ollama-selective-acceptance.service || true'
Restart=on-failure
RestartSec=30s
StandardOutput=append:/mnt/d/FAR-outputs/selective_acceptance_v2.log
StandardError=append:/mnt/d/FAR-outputs/selective_acceptance_v2.log

[Install]
WantedBy=default.target
