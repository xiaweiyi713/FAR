[Unit]
Description=FAR WS2 Mistral-only checkpoint resume
Wants=far-ollama-family-dev.service
After=far-ollama-family-dev.service

[Service]
Type=simple
WorkingDirectory=/mnt/d/FAR-workspace/FAR-longterm
ExecStartPre=/bin/bash -lc 'while :; do stable=1; for _ in 1 2 3; do curl -fsS --max-time 5 http://127.0.0.1:11434/api/tags >/dev/null || { stable=0; break; }; sleep 2; done; (( stable )) && exit 0; sleep 2; done'
ExecStart=/bin/bash -lc 'source ~/miniconda3/etc/profile.d/conda.sh; conda activate train; source scripts/windows_gpu_env.sh; exec python -m experiments.family_dev run-family --family mistral --input-dir /mnt/d/FAR-outputs/family_dev_input_v1 --output-dir /mnt/d/FAR-outputs/family_dev_v1'
Restart=on-failure
RestartSec=30s
StandardOutput=append:/mnt/d/FAR-outputs/family_dev_v1.log
StandardError=append:/mnt/d/FAR-outputs/family_dev_v1.log
