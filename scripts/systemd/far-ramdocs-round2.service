[Unit]
Description=FAR RAMDocs dev Round 2 method revision
Requires=far-ollama-2plus4.service
After=far-ollama-2plus4.service

[Service]
Type=simple
WorkingDirectory=/mnt/d/FAR-workspace/FAR-2plus4
Environment=PYTHONUNBUFFERED=1
ExecStartPre=/bin/bash -lc 'until curl -fsS --max-time 5 http://127.0.0.1:11434/api/tags >/dev/null; do sleep 2; done'
ExecStart=/bin/bash -lc 'source ~/miniconda3/etc/profile.d/conda.sh; conda activate train; source scripts/windows_gpu_env.sh; echo RAMDOCS_ROUND2_START $(date -Is) commit=$(git rev-parse HEAD) HF_HOME=$${HF_HOME} HUGGINGFACE_HUB_CACHE=$${HUGGINGFACE_HUB_CACHE} OLLAMA_MODELS=$${OLLAMA_MODELS}; exec python -m experiments.run_ramdocs run --config experiments/configs/ramdocs_qwen_round2.yaml --data-dir bench/external/ramdocs_v1 --initial-answers /mnt/d/FAR-outputs/ramdocs_dev_v1/initial_answers/predictions.jsonl --output-dir /mnt/d/FAR-outputs/ramdocs_dev_v2/runs/far --method far --split dev'
Restart=on-failure
RestartSec=10s
StandardOutput=append:/mnt/d/FAR-outputs/ramdocs_dev_v2.log
StandardError=append:/mnt/d/FAR-outputs/ramdocs_dev_v2.log

[Install]
WantedBy=default.target
