[Unit]
Description=FAR RAMDocs Phase A formal dev suite
Wants=far-ollama-2plus4.service
After=far-ollama-2plus4.service

[Service]
Type=simple
WorkingDirectory=/mnt/d/FAR-workspace/FAR-2plus4
Environment=PYTHONUNBUFFERED=1
ExecStartPre=/bin/bash -lc 'while :; do stable=1; for _ in 1 2 3; do curl -fsS --max-time 5 http://127.0.0.1:11434/api/tags >/dev/null || { stable=0; break; }; sleep 2; done; (( stable )) && exit 0; sleep 2; done'
ExecStart=/bin/bash -lc 'source ~/miniconda3/etc/profile.d/conda.sh; conda activate train; source scripts/windows_gpu_env.sh; echo RAMDOCS_SYSTEMD_START $(date -Is) commit=$(git rev-parse HEAD) HF_HOME=$${HF_HOME} HUGGINGFACE_HUB_CACHE=$${HUGGINGFACE_HUB_CACHE} OLLAMA_MODELS=$${OLLAMA_MODELS}; exec python -m experiments.ramdocs_suite run --config experiments/configs/ramdocs_qwen.yaml --data-dir bench/external/ramdocs_v1 --output-dir /mnt/d/FAR-outputs/ramdocs_dev_v1 --split dev'
Restart=on-failure
RestartSec=10s
StandardOutput=append:/mnt/d/FAR-outputs/ramdocs_dev_v1.log
StandardError=append:/mnt/d/FAR-outputs/ramdocs_dev_v1.log

[Install]
WantedBy=default.target
