[Unit]
Description=FAR registered P5 RAMDocs ablations
Wants=far-ollama-p5.service
After=far-ollama-p5.service

[Service]
Type=simple
WorkingDirectory=/mnt/d/FAR-workspace/FAR-longterm
Environment=PYTHONUNBUFFERED=1
ExecStartPre=/bin/bash -lc 'while :; do stable=1; for _ in 1 2 3; do curl -fsS --max-time 5 http://127.0.0.1:11434/api/tags >/dev/null || { stable=0; break; }; sleep 2; done; (( stable )) && exit 0; sleep 2; done'
ExecStart=/bin/bash -lc 'source ~/miniconda3/etc/profile.d/conda.sh; conda activate train; source scripts/windows_gpu_env.sh; echo P5_START $(date -Is) commit=$(git rev-parse HEAD); exec python -m far.experiments.p5_ablations run-all --output-dir /mnt/d/FAR-outputs/p5_ramdocs_v1 --report-json /mnt/d/FAR-outputs/p5_ramdocs_v1/p5_ramdocs_ablations.json --report-markdown /mnt/d/FAR-outputs/p5_ramdocs_v1/p5_ramdocs_ablations.md'
Restart=on-failure
RestartSec=30s
StandardOutput=append:/mnt/d/FAR-outputs/p5_ramdocs_v1.log
StandardError=append:/mnt/d/FAR-outputs/p5_ramdocs_v1.log

[Install]
WantedBy=default.target
