include PROJECT_PROPOSAL.md
include uv.lock
include .python-version
include .gitattributes
include .github/workflows/ci.yml

recursive-include docs *.md
recursive-include reports *.md *.csv *.json
recursive-include examples *.py
recursive-include scripts *.sh *.py
include submission/blind_test_attestation.template.json
include submission/evidence.template.json
recursive-include paper *.tex *.bib *.bst *.sty *.txt *.md

prune outputs
prune output
prune tmp
prune build
prune dist
prune bench
prune diagnostics
prune paper/aaai27
include paper/aaai27/ReproducibilityChecklist.tex
global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude *.aux *.bbl *.blg *.log *.out *.pdf *.fls *.fdb_latexmk *.synctex.gz
